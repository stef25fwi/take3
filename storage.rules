rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() { return request.auth != null; }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isMp4(name) { return name.matches('.*\\.mp4$'); }
    function isJpg(name) { return name.matches('.*\\.jpg$'); }

    // Vidéos de scènes : owner only, <= 50 MB, video/*
    match /scenes/{uid}/{fileName} {
      allow read: if true;
      allow write: if isSelf(uid)
        && isMp4(fileName)
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    // Thumbnails : owner only, <= 2 MB, image/*
    match /thumbnails/{uid}/{fileName} {
      allow read: if true;
      allow write: if isSelf(uid)
        && isJpg(fileName)
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Avatars : owner only, <= 2 MB, image/*
    match /avatars/{fileName} {
      allow read: if true;
      allow write: if fileName.matches('^' + request.auth.uid + '\\.jpg$')
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }

    // ======================================================
    // TAKE60 PROD EXACT STORAGE RULES
    // Paths réels détectés :
    // - scenes/{uid}/{sceneId}_{markerId}.mp4
    // - take60_renders/{uid}/{renderId}.mp4
    // - take60_renders/{uid}/{renderId}.jpg
    // ======================================================

    // Segments vidéo utilisateur Take60.
    // Le fichier est stocké dans le même dossier que les scènes classiques.
    match /scenes/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 300 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    // Rendus finaux générés côté Cloud Functions.
    // L'écriture se fait via Admin SDK, donc pas besoin d'autoriser le client.
    match /take60_renders/{userId}/{fileName} {
      allow read: if true;
      allow write: if false;
    }


  }
}
