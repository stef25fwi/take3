rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() { return request.auth != null; }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Vidéos de scènes : owner only, <= 50 MB, video/*
    match /scenes/{uid}/{sceneId}.mp4 {
      allow read: if true;
      allow write: if isSelf(uid)
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    // Thumbnails : owner only, <= 2 MB, image/*
    match /thumbnails/{uid}/{sceneId}.jpg {
      allow read: if true;
      allow write: if isSelf(uid)
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Avatars : owner only, <= 2 MB, image/*
    match /avatars/{uid}.jpg {
      allow read: if true;
      allow write: if isSelf(uid)
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
