rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() { return request.auth != null; }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isMp4(name) { return name.matches('.*\\.mp4$'); }
    function isJpg(name) { return name.matches('.*\\.jpg$'); }

    // Vidéos de scènes : owner only, <= 50 MB, video/*
    match /scenes/{uid}/{fileName} {
      allow read: if true;
      allow write: if isSelf(uid)
        && isMp4(fileName)
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    // Thumbnails : owner only, <= 2 MB, image/*
    match /thumbnails/{uid}/{fileName} {
      allow read: if true;
      allow write: if isSelf(uid)
        && isJpg(fileName)
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Avatars : owner only, <= 2 MB, image/*
    match /avatars/{fileName} {
      allow read: if true;
      allow write: if fileName.matches('^' + request.auth.uid + '\\.jpg$')
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        request.auth.token.superAdmin == true
      );
    }

    // Segments vidéo utilisateur Take60.
    match /take60_user_recordings/{userId}/{projectId}/{fileName} {
      allow read: if true;
      allow write: if isSelf(userId)
        && fileName.matches('.*\\.mp4$')
        && request.resource.size < 300 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    match /take60/raw_uploads/{userId}/{fileName} {
      allow read: if isSelf(userId) || isAdmin();
      allow write: if isSelf(userId)
        && fileName.matches('.*\.mp4$')
        && request.resource.size < 300 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    match /take60/processed/{videoId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Copies finales dédiées aux Battles.
    // Nouveau chemin additif ; l'ancien flux take60_renders reste supporté.
    match /battles/{battleId}/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSelf(userId)
        && fileName.matches('.*\\.mp4$')
        && request.resource.size < 300 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    // Rendus finaux générés côté Cloud Functions.
    // L'écriture se fait via Admin SDK, donc pas besoin d'autoriser le client.
    match /take60_renders/{userId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }


  }
}
