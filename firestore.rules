rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAuthor() {
      return isSignedIn() && resource.data.authorId == request.auth.uid;
    }
    // Champs réservés aux Cloud Functions (jamais écrits par le client).
    function writesNoCounters(allowed) {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(allowed);
    }

    // ─── users ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if true;
      allow create: if isSelf(uid)
        && request.resource.data.keys().hasAll(['username', 'displayName', 'avatarUrl', 'createdAt'])
        && request.resource.data.scenesCount == 0
        && request.resource.data.followersCount == 0;
      // L'utilisateur peut éditer son profil mais pas ses compteurs.
      allow update: if isSelf(uid)
        && writesNoCounters(['displayName', 'avatarUrl', 'bio', 'username', 'fcmTokens', 'lastActiveAt']);
      allow delete: if false;

      // Sous-collections écrites uniquement par Functions.
      match /followers/{followerId} {
        allow read: if true;
        allow write: if false;
      }
      match /following/{followeeId} {
        allow read: if true;
        allow write: if false;
      }
      match /badges/{badgeId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ─── scenes ─────────────────────────────────────────────────────────────
    match /scenes/{sceneId} {
      allow read: if resource == null || resource.data.status == 'published' || isAuthor();
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.likesCount == 0
        && request.resource.data.commentsCount == 0
        && request.resource.data.viewsCount == 0
        && request.resource.data.sharesCount == 0
        && request.resource.data.status in ['draft', 'published'];
      allow update: if isAuthor()
        && writesNoCounters(['title', 'category', 'thumbnailUrl', 'videoUrl', 'tags', 'status', 'updatedAt']);
      allow delete: if isAuthor();

      // Commentaires : lecture publique, CRUD par l'auteur du commentaire.
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.likesCount == 0;
        allow update, delete: if isSignedIn()
          && resource.data.authorId == request.auth.uid;
      }

      // Likes : unicité par user, pas de double like.
      match /likes/{uid} {
        allow read: if true;
        allow create: if isSelf(uid)
          && !exists(/databases/$(database)/documents/scenes/$(sceneId)/likes/$(uid));
        allow delete: if isSelf(uid);
        allow update: if false;
      }
    }

    // ─── notifications : lecture par le destinataire, écriture via Functions ──
    match /notifications/{uid}/items/{notifId} {
      allow read: if isSelf(uid);
      allow update: if isSelf(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow create, delete: if false;
    }

    // ─── duels ──────────────────────────────────────────────────────────────
    match /duels/{duelId} {
      allow read: if true;
      allow write: if false;

      match /votes/{uid} {
        allow read: if true;
        allow create: if isSelf(uid)
          && request.resource.data.choice in ['A', 'B']
          && !exists(/databases/$(database)/documents/duels/$(duelId)/votes/$(uid));
        allow update, delete: if false;
      }
    }

    // ─── battles Take60 : écritures sensibles via Cloud Functions ──────────
    function isBattleParticipantFor(battleId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/battles/$(battleId)).data.challengerId == request.auth.uid ||
        get(/databases/$(database)/documents/battles/$(battleId)).data.opponentId == request.auth.uid
      );
    }

    function isVisibleBattleStatus(status) {
      return status in [
        'in_preparation',
        'waiting_challenger_submission',
        'waiting_opponent_submission',
        'ready_to_publish',
        'published',
        'voting_open',
        'ended',
        'forfeit'
      ];
    }

    match /battles/{battleId} {
      allow read: if isSignedIn() && (
        isVisibleBattleStatus(resource.data.status) ||
        resource.data.challengerId == request.auth.uid ||
        resource.data.opponentId == request.auth.uid
      );
      allow create, update, delete: if false;

      match /followers/{uid} {
        allow read: if isSignedIn();
        allow write: if false;
      }
      match /votes/{uid} {
        allow read: if isBattleParticipantFor(battleId);
        allow write: if false;
      }
      match /predictions/{uid} {
        allow read: if isSelf(uid) || isBattleParticipantFor(battleId);
        allow write: if false;
      }
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          && request.resource.data.status in ['visible', 'reported'];
        allow update, delete: if false;
      }
      match /reports/{reportId} {
        allow create: if isSignedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.reason is string;
        allow read, update, delete: if false;
      }
      match /events/{eventId} {
        allow read: if isBattleParticipantFor(battleId);
        allow write: if false;
      }
    }

    match /battleRivalries/{pairKey} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /userBattleStats/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ─── daily challenges ───────────────────────────────────────────────────
    match /dailyChallenges/{dateKey} {
      allow read: if true;
      allow write: if false;

      match /participants/{uid} {
        allow read: if true;
        allow create: if isSelf(uid);
        allow update, delete: if false;
      }
    }

    // ─── leaderboards / categories : read public, write Functions only ──────
    match /leaderboards/{period}/entries/{entryId} {
      allow read: if true;
      allow write: if false;
    }
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    // ─── feed fan-out : lecture par le destinataire uniquement ──────────────
    match /feed/{uid}/items/{sceneId} {
      allow read: if isSelf(uid);
      allow write: if false;
    }

    // Tout le reste est refusé par défaut.

    // ======================================================
    // TAKE60 PROD EXACT RULES
    // Collections réelles détectées :
    // - scenes adminWorkflow
    // - take60_user_recordings
    // - take60_guided_projects
    // - take60_renders
    // ======================================================

    function take60IsAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        request.auth.token.superAdmin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.superAdmin == true
          )
        )
      );
    }

    function take60IsOwnerByData(data) {
      return request.auth != null && (
        data.userId == request.auth.uid ||
        data.ownerId == request.auth.uid ||
        data.authorId == request.auth.uid ||
        data.createdBy == request.auth.uid
      );
    }

    // Scènes guidées Take60 publiées / prêtes.
    // Le client charge collection('scenes').where('adminWorkflow', isEqualTo: true)
    match /scenes/{sceneId} {
      allow read: if resource.data.adminWorkflow == true && (
        resource.data.status == 'published' ||
        resource.data.publicationStatus == 'published' ||
        resource.data.ready == true ||
        resource.data.isPublished == true ||
        take60IsAdmin()
      );

      allow create, update, delete: if take60IsAdmin();
    }

    // Métadonnées des segments enregistrés par l'utilisateur.
    // Client : collection('take60_user_recordings')
    match /take60_user_recordings/{recordingId} {
      allow create: if request.auth != null && take60IsOwnerByData(request.resource.data);

      allow read: if take60IsAdmin() || take60IsOwnerByData(resource.data);

      allow update: if take60IsAdmin() || (
        take60IsOwnerByData(resource.data) &&
        take60IsOwnerByData(request.resource.data)
      );

      allow delete: if take60IsAdmin() || take60IsOwnerByData(resource.data);
    }

    // Projets guidés sauvegardés côté client.
    // Client : collection('take60_guided_projects')
    match /take60_guided_projects/{projectId} {
      allow create: if request.auth != null && take60IsOwnerByData(request.resource.data);

      allow read: if take60IsAdmin() || take60IsOwnerByData(resource.data);

      allow update: if take60IsAdmin() || (
        take60IsOwnerByData(resource.data) &&
        take60IsOwnerByData(request.resource.data)
      );

      allow delete: if take60IsAdmin() || take60IsOwnerByData(resource.data);

      match /segments/{segmentId} {
        allow create: if request.auth != null && take60IsOwnerByData(request.resource.data);

        allow read: if take60IsAdmin() || take60IsOwnerByData(resource.data);

        allow update: if take60IsAdmin() || (
          take60IsOwnerByData(resource.data) &&
          take60IsOwnerByData(request.resource.data)
        );

        allow delete: if take60IsAdmin() || take60IsOwnerByData(resource.data);
      }
    }

    match /takes/{takeId} {
      allow create: if request.auth != null
        && take60IsOwnerByData(request.resource.data)
        && request.resource.data.videoUrl is string
        && request.resource.data.videoUrl != '';

      allow read: if true;

      allow update: if take60IsAdmin() || (
        take60IsOwnerByData(resource.data) &&
        take60IsOwnerByData(request.resource.data) &&
        request.resource.data.videoUrl is string &&
        request.resource.data.videoUrl != ''
      );

      allow delete: if take60IsAdmin() || take60IsOwnerByData(resource.data);
    }

    // Rendus serveur créés par Cloud Functions Admin SDK.
    // Function : db.collection("take60_renders")
    // Le client peut lire son rendu, mais ne doit pas l'écrire directement.
    match /take60_renders/{renderId} {
      allow read: if take60IsAdmin() || take60IsOwnerByData(resource.data);

      allow create, update, delete: if take60IsAdmin();
    }


    match /{document=**} {
      allow read, write: if false;
    }
  }
}
