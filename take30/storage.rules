rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /scenes/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId)
        && request.resource.size < 300 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    match /thumbnails/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /avatars/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
        && fileName == request.auth.uid + '.jpg'
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        request.auth.token.superAdmin == true
      );
    }

    // Segments vidéo utilisateur Take60.
    match /take60_user_recordings/{userId}/{projectId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId)
        && fileName.matches('.*\\.mp4$')
        && request.resource.size < 300 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    // Rendus finaux générés côté Cloud Functions.
    // L'écriture se fait via Admin SDK, donc pas besoin d'autoriser le client.
    match /take60_renders/{userId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }


  }
}
