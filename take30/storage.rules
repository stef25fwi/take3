rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function isOwner(userId) { return signedIn() && request.auth.uid == userId; }

    match /scenes/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId)
        && request.resource.size < 300 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    match /thumbnails/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /avatars/{fileName} {
      allow read: if true;
      allow write: if signedIn()
        && fileName == request.auth.uid + '.jpg'
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }

    // ======================================================
    // TAKE60 PROD EXACT STORAGE RULES
    // Paths réels détectés :
    // - scenes/{uid}/{sceneId}_{markerId}.mp4
    // - take60_renders/{uid}/{renderId}.mp4
    // - take60_renders/{uid}/{renderId}.jpg
    // ======================================================

    // Segments vidéo utilisateur Take60.
    // Le fichier est stocké dans le même dossier que les scènes classiques.
    match /scenes/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 300 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    // Rendus finaux générés côté Cloud Functions.
    // L'écriture se fait via Admin SDK, donc pas besoin d'autoriser le client.
    match /take60_renders/{userId}/{fileName} {
      allow read: if true;
      allow write: if false;
    }


  }
}
