rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isOwner(userId) { return signedIn() && request.auth.uid == userId; }
    function userDocExists() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function isAdmin() {
      return signedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (
          userDocExists() && (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          )
        )
      );
    }
    function sameSceneOwner() {
      return signedIn() && request.resource.data.authorId == request.auth.uid;
    }
    function sceneCriticalFieldsUnchanged() {
      return request.resource.data.veoStatus == resource.data.veoStatus &&
        request.resource.data.veoPrompt == resource.data.veoPrompt &&
        request.resource.data.veoOperationId == resource.data.veoOperationId &&
        request.resource.data.veoError == resource.data.veoError &&
        request.resource.data.videoUrl == resource.data.videoUrl &&
        request.resource.data.thumbnailUrl == resource.data.thumbnailUrl &&
        request.resource.data.createdBy == resource.data.createdBy;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if false;

      match /followers/{followerId} {
        allow read: if true;
        allow create, delete: if signedIn();
        allow update: if false;
      }

      match /following/{followingId} {
        allow read: if true;
        allow create, delete: if isOwner(userId);
        allow update: if false;
      }
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /scenes/{sceneId} {
      allow read: if true;
      allow create: if signedIn() && (sameSceneOwner() || isAdmin());
      allow update, delete: if isAdmin() ||
        (signedIn() && resource.data.authorId == request.auth.uid && sceneCriticalFieldsUnchanged());

      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if signedIn() && resource.data.authorId == request.auth.uid;
      }

      match /likes/{userId} {
        allow read: if true;
        allow create, delete: if isOwner(userId);
        allow update: if false;
      }

      match /views/{viewerId} {
        allow read, write: if false;
      }
    }

    match /takes/{takeId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn();
    }

    match /notifications/{userId}/items/{itemId} {
      allow read, update, delete: if isOwner(userId);
      allow create: if false;
    }


    // ======================================================
    // TAKE60 PROD EXACT RULES
    // Collections réelles détectées :
    // - scenes adminWorkflow
    // - take60_user_recordings
    // - take60_guided_projects
    // - take60_renders
    // ======================================================

    function take60IsAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        request.auth.token.superAdmin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.superAdmin == true
          )
        )
      );
    }

    function take60IsOwnerByData(data) {
      return request.auth != null && (
        data.userId == request.auth.uid ||
        data.ownerId == request.auth.uid ||
        data.authorId == request.auth.uid ||
        data.createdBy == request.auth.uid
      );
    }

    // Scènes guidées Take60 publiées / prêtes.
    // Le client charge collection('scenes').where('adminWorkflow', isEqualTo: true)
    match /scenes/{sceneId} {
      allow read: if resource.data.adminWorkflow == true && (
        resource.data.status == 'published' ||
        resource.data.publicationStatus == 'published' ||
        resource.data.ready == true ||
        resource.data.isPublished == true ||
        take60IsAdmin()
      );

      allow create, update, delete: if take60IsAdmin();
    }

    // Métadonnées des segments enregistrés par l'utilisateur.
    // Client : collection('take60_user_recordings')
    match /take60_user_recordings/{recordingId} {
      allow create: if request.auth != null && take60IsOwnerByData(request.resource.data);

      allow read: if take60IsAdmin() || take60IsOwnerByData(resource.data);

      allow update: if take60IsAdmin() || (
        take60IsOwnerByData(resource.data) &&
        take60IsOwnerByData(request.resource.data)
      );

      allow delete: if take60IsAdmin() || take60IsOwnerByData(resource.data);
    }

    // Projets guidés sauvegardés côté client.
    // Client : collection('take60_guided_projects')
    match /take60_guided_projects/{projectId} {
      allow create: if request.auth != null && take60IsOwnerByData(request.resource.data);

      allow read: if take60IsAdmin() || take60IsOwnerByData(resource.data);

      allow update: if take60IsAdmin() || (
        take60IsOwnerByData(resource.data) &&
        take60IsOwnerByData(request.resource.data)
      );

      allow delete: if take60IsAdmin() || take60IsOwnerByData(resource.data);

      match /segments/{segmentId} {
        allow create: if request.auth != null && take60IsOwnerByData(request.resource.data);

        allow read: if take60IsAdmin() || take60IsOwnerByData(resource.data);

        allow update: if take60IsAdmin() || (
          take60IsOwnerByData(resource.data) &&
          take60IsOwnerByData(request.resource.data)
        );

        allow delete: if take60IsAdmin() || take60IsOwnerByData(resource.data);
      }
    }

    match /takes/{takeId} {
      allow create: if request.auth != null
        && take60IsOwnerByData(request.resource.data)
        && request.resource.data.videoUrl is string
        && request.resource.data.videoUrl != '';

      allow read: if true;

      allow update: if take60IsAdmin() || (
        take60IsOwnerByData(resource.data) &&
        take60IsOwnerByData(request.resource.data) &&
        request.resource.data.videoUrl is string &&
        request.resource.data.videoUrl != ''
      );

      allow delete: if take60IsAdmin() || take60IsOwnerByData(resource.data);
    }

    // Rendus serveur créés par Cloud Functions Admin SDK.
    // Function : db.collection("take60_renders")
    // Le client peut lire son rendu, mais ne doit pas l'écrire directement.
    match /take60_renders/{renderId} {
      allow read: if take60IsAdmin() || take60IsOwnerByData(resource.data);

      allow create, update, delete: if take60IsAdmin();
    }


    match /{document=**} {
      allow read, write: if false;
    }
  }
}
